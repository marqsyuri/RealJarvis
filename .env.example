# Renomeie para .env e preencha com suas chaves
# (adicione .env ao .gitignore para não commitar a key)

# ElevenLabs — obtenha em https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Voice ID — copie da URL na voice library
# Ex: https://elevenlabs.io/app/voice-library/jarvis → pegar o ID da URL
# Sugestões JARVIS-like: buscar "jarvis", "ai", "sci-fi" na voice library
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
